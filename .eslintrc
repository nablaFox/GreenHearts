{
	"root": true,
	"parser": "vue-eslint-parser",
	"extends": [
		"plugin:vue/vue3-recommended"
	],
	"parserOptions": {
		"parser": "@typescript-eslint/parser",
		"sourceType": "module"
	},
	"rules": {
		"vue/multi-word-component-names": "off",
		"vue/no-deprecated-slot-attribute": "off",
		"indent": [
			"error",
			"tab"
		],
		"quotes": [
			"error",
			"single"
		],
		"semi": [
			"error",
			"never"
		],
		"object-curly-spacing": [
			"error",
			"always"
		]
	}
}
