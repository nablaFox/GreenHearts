rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
		function isAdmin(request, userId) {
        	return request.auth.token.admin == true
				|| request.auth.uid in get(/databases/$(database)/documents/users/$(userId)).data.admins
    }
    
    function isSameUser(request, userId) {
    	return request.auth.uid == userId
    }
    
    match /users/{userId} {
    	allow read: if isSameUser(request, userId)
		allow write, delete, read: if isAdmin(request, userId)
    }
    
    match /users/{userId}/posts/{post} {
		allow read, delete, write: if isAdmin(request, userId) 
		allow read, write: if isSameUser(request, userId) //tmp: allow write only if Admin
    }  
  }
}
